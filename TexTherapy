// POSTIT BOARD (shared storage)
// ══════════════════════════════════════════
const BOARD_KEY = 'mindrefresh-board';

function getBoard() {
  try {
    return JSON.parse(localStorage.getItem(BOARD_KEY) || '[]');
  } catch(e) { return []; }
}
function saveBoard(arr) {
  try { localStorage.setItem(BOARD_KEY, JSON.stringify(arr)); } catch(e) {}
}

async function submitPostit() {
  const newThought = document.getElementById('popup-new').textContent.trim();
  if (!newThought) return;
  const board = getBoard();
  board.unshift({
    text: newThought,
    ts: Date.now(),
    color: pastelColors[Math.floor(Math.random() * pastelColors.length)]
  });
  // 최대 50개 유지
  if (board.length > 50) board.pop();
  saveBoard(board);

  // 버튼 영역을 감사 메시지로 교체
  const shareArea = document.querySelector('#result-popup .result-card > div:nth-last-child(2)');
  if (shareArea) {
    shareArea.innerHTML = '<div style="text-align:center;font-size:13px;color:var(--mint-deep);padding:6px 0;">📌 게시판에 붙였어요! 다음 사람에게 힘이 될 거예요 💚</div>';
  }
}

function skipPostit() {
  const shareArea = document.querySelector('#result-popup .result-card > div:nth-last-child(2)');
  if (shareArea) {
    shareArea.innerHTML = '<div style="text-align:center;font-size:13px;color:#aaa;padding:6px 0;">🙂 비공개로 간직해요. 그것도 충분히 괜찮아요.</div>';
  }
}

const pastelColors = [
  { bg:'#fff9c4', border:'#f9e14b' },
  { bg:'#fce4ec', border:'#f48fb1' },
  { bg:'#e8f5e9', border:'#a5d6a7' },
  { bg:'#e3f2fd', border:'#90caf9' },
  { bg:'#f3e5f5', border:'#ce93d8' },
  { bg:'#fff3e0', border:'#ffcc80' },
  { bg:'#e0f7fa', border:'#80deea' },
];

function renderBoard() {
  const board = getBoard();
  const grid = document.getElementById('board-grid');
  const empty = document.getElementById('board-empty');
  if (!board.length) {
    if (empty) empty.style.display = 'block';
    return;
  }
  if (empty) empty.style.display = 'none';
  // remove existing postits (keep empty msg)
  grid.querySelectorAll('.postit').forEach(el => el.remove());

  board.forEach((item, i) => {
    const el = document.createElement('div');
    el.className = 'postit';
    const date = new Date(item.ts);
    const label = `${date.getMonth()+1}/${date.getDate()}`;
    el.style.cssText = `
      background:${item.color.bg};
      border:1.5px solid ${item.color.border};
      border-radius:4px 14px 4px 4px;
      padding:12px 10px 10px;
      font-size:13px;
      color:#444;
      line-height:1.55;
      position:relative;
      box-shadow:2px 3px 8px rgba(0,0,0,0.08);
      animation: postitIn 0.3s cubic-bezier(.22,1,.36,1) ${i*0.04}s both;
      min-height:90px;
      word-break:keep-all;
    `;
    // XSS 방지: textContent 사용
    const dateDiv = document.createElement('div');
    dateDiv.style.cssText = 'font-size:10px;color:#bbb;margin-bottom:6px;';
    dateDiv.textContent = `🌱 ${label}`;
    const textDiv = document.createElement('div');
    textDiv.textContent = item.text;
    el.appendChild(dateDiv);
    el.appendChild(textDiv);
    grid.appendChild(el);
  });
}

function openBoard() {
  renderBoard();
  document.getElementById('win-board').style.display = 'flex';
}
function closeBoard() {
  document.getElementById('win-board').style.display = 'none';
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

// ══════════════════════════════════════════
// DRAGGABLE WINDOWS
// ══════════════════════════════════════════
(function initDrag() {
  let dragging = null, ox = 0, oy = 0;

  function getPos(el) {
    const r = el.getBoundingClientRect();
    return { x: r.left, y: r.top };
  }

  function startDrag(e, win) {
    // 닫기/최소화/최대화 버튼 클릭 시 드래그 무시
    if (e.target.closest('.win-btns')) return;
    e.preventDefault();
    dragging = win;
    // transform 해제하고 현재 실제 위치로 고정
    const r = win.getBoundingClientRect();
    win.style.transform = 'none';
    win.style.left = r.left + 'px';
    win.style.top  = r.top  + 'px';
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    ox = clientX - r.left;
    oy = clientY - r.top;
    win.style.zIndex = nextZ();
    win.style.transition = 'none';
  }

  function onMove(e) {
    if (!dragging) return;
    const clientX = e.touches ? e.touches[0].clientX : e.clientX;
    const clientY = e.touches ? e.touches[0].clientY : e.clientY;
    let nx = clientX - ox;
    let ny = clientY - oy;
    // 화면 밖으로 나가지 않도록 제한
    const w = dragging.offsetWidth;
    const h = dragging.offsetHeight;
    nx = Math.max(0, Math.min(window.innerWidth  - w, nx));
    ny = Math.max(0, Math.min(window.innerHeight - 56 - h, ny));
    dragging.style.left = nx + 'px';
    dragging.style.top  = ny + 'px';
  }

  function endDrag() {
    if (dragging) dragging.style.transition = '';
    dragging = null;
  }

  let zCounter = 10;
  function nextZ() { return ++zCounter; }

  document.addEventListener('mousemove',  onMove);
  document.addEventListener('mouseup',    endDrag);
  document.addEventListener('touchmove',  onMove, { passive: false });
  document.addEventListener('touchend',   endDrag);

  // 창이 렌더된 뒤 titlebar에 이벤트 붙이기
  function bindAll() {
    document.querySelectorAll('.win-titlebar').forEach(bar => {
      const win = bar.closest('.window');
      if (!win || bar._dragBound) return;
      bar._dragBound = true;
      bar.addEventListener('mousedown',  e => startDrag(e, win));
      bar.addEventListener('touchstart', e => startDrag(e, win), { passive: false });
      // 창 클릭 시 최상위로
      win.addEventListener('mousedown', () => { win.style.zIndex = nextZ(); });
    });
  }

  // 초기 + showWindow 호출 후에도 bind
  const origShow = window.showWindow;
  window.showWindow = function(n) {
    origShow(n);
    setTimeout(bindAll, 50);
  };
  const origOpenBoard = window.openBoard;
  window.openBoard = function() {
    origOpenBoard();
    setTimeout(bindAll, 50);
  };
  setTimeout(bindAll, 100);
})();

