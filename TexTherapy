  document.getElementById('icon2').style.pointerEvents = 'auto';
  document.getElementById('task2').style.display = 'flex';
  showWindow(2);

  // Build checklist
  buildChecklist();

  // Show loading
  document.getElementById('scan-loading').style.display = 'block';
  document.getElementById('scan-result').style.display = 'none';

  const msgs = nlpOn
    ? ['AI가 감정 맥락을 파악 중...','깊은 패턴 분석 중...','위로 문장 생성 중...']
    : ['키워드 패턴 스캔 중...','인지 왜곡 데이터베이스 대조 중...','결과 정리 중...'];

  let prog = 0;
  const bar = document.getElementById('scan-progress');
  const lmsg = document.getElementById('loading-msg');
  const delay = nlpOn ? 600 : 300;
  for (let i = 0; i < msgs.length; i++) {
    lmsg.textContent = msgs[i];
    prog = Math.round((i+1)/msgs.length*100);
    bar.style.width = prog + '%';
    await sleep(delay);
  }

  // ── 위기 신호 먼저 체크 (AI 문맥 재확인) ──
  const hasCrisisKw = crisisKeywords.some(kw => text.includes(kw));
  if (hasCrisisKw) {
    // AI로 문맥이 실제 위기인지 재확인
    let isCrisis = true;
    try {
      const cr = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 10,
          messages: [{
            role: 'user',
            content: `다음 문장이 자해·자살·삶을 끝내고 싶은 감정을 직접 표현하고 있나요? "예" 또는 "아니오"만 출력하세요.\n\n문장: "${text.replace(/"/g,"'")}"`
          }]
        })
      });
      const cd = await cr.json();
      const cv = cd.content.map(b => b.text || '').join('').trim();
      isCrisis = cv.includes('예');
    } catch(e) { /* 연결 실패 시 위기로 간주 */ }

    if (isCrisis) {
      document.getElementById('scan-loading').style.display = 'none';
      document.getElementById('scan-result').style.display = 'block';
      const alertBox = document.getElementById('alert-box');
      alertBox.className = 'scan-alert crisis';
      document.getElementById('alert-text').innerHTML = `
        <div class="crisis-title">🚨 지금 많이 힘드신 것 같아요</div>
        지금 이 감정이 아주 크고 무겁게 느껴지겠지만, 혼자 버티지 않아도 돼요.<br>
        지금 당장 아래 번호로 연락해보세요. 24시간 언제든 들어줄 수 있는 분들이 있어요.
        <div class="crisis-hotline">
          <strong>📞 자살예방상담전화 1393</strong> — 24시간, 무료<br>
          <strong>📞 청소년전화 1388</strong> — 24시간, 무료<br>
          <strong>📞 정신건강위기상담전화 1577-0199</strong> — 24시간, 무료
        </div>
      `;
      document.getElementById('ai-detail').innerHTML = `
        지금 느끼는 감정은 진짜이고, 그 고통도 진짜예요. 하지만 이 감정이 영원히 이어지지는 않아요.<br>
        위 번호로 전화하거나 문자를 보내면, 지금 이 마음을 함께 들어줄 사람이 있어요.
      `;
      return; // 일반 분석 스킵
    }
  }

  // Detect (일반 패턴)
  const local = localScan(text);
  detectedPatterns = local;

  let alertHTML, aiDetailHTML;

  if (nlpOn) {
    lmsg.textContent = 'AI 분석 완료 중...';
    try {
      const aiRes = await aiScan(text);
      const pats = aiRes.patterns.length ? aiRes.patterns.join(', ') : '패턴 없음';
      alertHTML = local.length
        ? `<strong>⚠️ 감지:</strong> <strong>${pats}</strong> 패턴이 발견되었어요. 괜찮아요, 함께 살펴봐요.`
        : `<strong>✅ 특별한 패턴 없음</strong> — 그래도 아래 체크리스트를 한 번 살펴봐요.`;
      aiDetailHTML = aiRes.feedback || '분석 완료';
      scanResultText = aiRes.feedback || '';
      highlightDetected(aiRes.patterns);
    } catch(e) {
      alertHTML = '⚠️ AI 연결 오류 — 로컬 분석으로 대체합니다.';
      aiDetailHTML = local.length
        ? `로컬 분석: ${local.map(p=>p.label).join(', ')} 패턴이 발견되었어요.`
        : '특별한 패턴이 감지되지 않았어요.';
      highlightDetected(local.map(p=>p.label));
    }
  } else {
    if (local.length) {
      const types = local.map(p=>p.label);
      const danger = local.some(p=>p.type==='danger');
      alertHTML = `<strong>${danger?'⚠️ 경고':'📋 감지'}:</strong> <strong>[${types.join('] [')}]</strong> 패턴이 감지되었어요.`;
      aiDetailHTML = `"${text}"에서 <strong>${types.join(', ')}</strong> 유형이 발견되었어요.<br>이런 생각은 자주 과장되어 느껴질 수 있어요. 실제로는 그렇지 않을 가능성이 높아요 🌱`;
      scanResultText = aiDetailHTML;
    } else {
      alertHTML = '✅ 특정 인지 왜곡 키워드는 발견되지 않았어요.';
      aiDetailHTML = '아래 체크리스트를 보면서 혹시 해당되는 부분이 있는지 살펴봐요.';
      scanResultText = aiDetailHTML;
    }
    highlightDetected(local.map(p=>p.label));
  }

  // Apply alert style
  const alertBox = document.getElementById('alert-box');
  const hasCrisisLocal = local.some(p=>p.type==='crisis');
  const hasDanger = local.some(p=>p.type==='danger');
  alertBox.className = 'scan-alert ' + (hasCrisisLocal ? 'crisis' : hasDanger ? 'danger' : local.length ? 'warn' : 'safe');
  document.getElementById('alert-text').innerHTML = alertHTML;
  document.getElementById('ai-detail').innerHTML = aiDetailHTML;

  document.getElementById('scan-loading').style.display = 'none';
  document.getElementById('scan-result').style.display = 'block';
}

function highlightDetected(patterns) {
  document.querySelectorAll('.check-item').forEach(item => {
    const txt = item.dataset.text || '';
    // auto-check items that seem related
    patterns.forEach(p => {
      if (txt.includes('실패') && p.includes('일반화')) item.querySelector('input').checked = true;
      if (txt.includes('완벽') && p.includes('당위')) item.querySelector('input').checked = true;
    });
  });
}

function buildChecklist() {
  const grid = document.getElementById('checklist-grid');
  grid.innerHTML = checklistItems.map(item => `
    <label class="check-item" data-text="${item.text}">
      <input type="checkbox" onchange="this.closest('.check-item').classList.toggle('checked',this.checked)">
      <span>${item.text}</span>
    </label>
  `).join('');
}

