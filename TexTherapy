function localScan(text) {
  const found = [];
  for (const rule of keywordDB) {
    for (const kw of rule.keywords) {
      if (text.includes(kw)) { found.push(rule); break; }
    }
  }
  return found;
}

// ══════════════════════════════════════════
// AI SCAN (Claude API)
// ══════════════════════════════════════════
async function aiScan(text) {
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1000,
      messages: [{
        role: 'user',
        content: `당신은 청소년 심리 상담 전문가입니다. 아래 문장을 읽고 다음 두 가지를 JSON으로 출력하세요 (다른 텍스트 없이 JSON만):
{
  "patterns": ["감지된 심리 패턴 이름1", "패턴2"],
  "feedback": "2~3문장의 따뜻하고 공감적인 한국어 피드백. 청소년에게 말하듯 부드럽게."
}

문장: "${text.replace(/"/g,'\'')}"

감지 대상 패턴 (아래 중 해당하는 것 모두 포함):
- 인지왜곡: 흑백논리, 과도한일반화, 재앙화, 자기비난, 독심술, 정서적탈진, 당위적사고, 부정편향, 임의적추론, 사회적비교
- 감정 상태: 우울감, 무기력, 극심한불안, 절망감
- 위기신호: 자해충동, 자살충동, 삶을포기하고싶은마음 (죽고 싶다, 사라지고 싶다, 살기 싫다 등의 표현이 부정적 맥락으로 쓰인 경우)

※ 위기신호가 감지된 경우 feedback에 반드시 따뜻하게 공감하고, 혼자가 아님을 알려주는 내용을 포함하세요.`
      }]
    })
  });
  const data = await res.json();
  const raw = data.content.map(b => b.text || '').join('');
  try {
    return JSON.parse(raw.replace(/```json|```/g,'').trim());
  } catch(e) {
    return { patterns: ['분석 완료'], feedback: raw };
  }
}

