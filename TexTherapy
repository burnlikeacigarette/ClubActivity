        warn.style.color = '#c0002a';
        return;
      }
    } catch(e) {
      // 연결 실패 시 위기로 간주
      warn.innerHTML = `🚨 위로 카드에는 이런 표현을 담을 수 없어요.<br>
        <span style="font-size:12px;line-height:1.8;display:block;margin-top:4px;">
