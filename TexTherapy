- 청소년이 실제로 쓸 법한 자연스러운 한국어로, 과하게 긍정적이지 않고 현실적으로 작성하세요.
- 다양한 접근: 자기 수용 / 성장 관점 / 현재에 집중 / 관계 재해석 / 작은 성공 인정 중 이전과 다른 관점을 선택하세요.

이전 제안들 (이것들과 달라야 함): ${prevSuggestions.length ? prevSuggestions.join(' / ') : '없음'}`
        }]
      })
    });
    const data = await res.json();
    const raw = data.content.map(b => b.text || '').join('').trim();
    const suggestion = raw.replace(/^["'"""''\-—–\s]+|["'"""''\-—–\s]+$/g, '').trim();

    // 제안 기록 저장 (최대 5개 유지)
    prevSuggestions.push(suggestion);
    if (prevSuggestions.length > 5) prevSuggestions.shift();
    window._prevSuggestions = prevSuggestions;

    if (forBlock) {
      // 차단 박스에 표시
      document.getElementById('suggest-preview').textContent = suggestion;
      window._currentSuggestion = suggestion;
    } else {
      document.getElementById('new-thought-input').value = suggestion;
      checkNegative();
    }
  } catch(e) {
    const fallbacks = [
      '오늘 이 순간도 버텨낸 나 자신을 조금은 인정해줄 수 있어.',
      '완벽하지 않아도 괜찮아. 지금 이 자리에 있는 것만으로도 충분해.',
      '이 상황이 영원히 이어지지는 않을 거야. 조금씩 달라질 수 있어.',
      '지금 느끼는 감정은 진짜이지만, 그게 미래를 결정하지는 않아.',
      '실수해도 돼. 그게 사람이 자라는 방식이니까.'
    ];
    const fb = fallbacks[Math.floor(Math.random() * fallbacks.length)];
    if (forBlock) {
      document.getElementById('suggest-preview').textContent = fb;
      window._currentSuggestion = fb;
    } else {
      document.getElementById('new-thought-input').value = fb;
    }
  }

  if (!forBlock) {
    btn.textContent = '✨ AI 긍정 생각 제안받기 — 막막하다면 클릭!';
    btn.style.opacity = '1';
  }
}

// 리롤
async function rerollSuggestion() {
  const btn = document.getElementById('reroll-btn');
  btn.textContent = '⏳ 생성 중...';
  btn.disabled = true;
  await aiSuggestPositive(true);
  btn.textContent = '🎲 다른 문장';
  btn.disabled = false;
}

// 추천 문장 수락 → 입력창에 적용 후 위로 카드 팝업
function acceptSuggestion() {
  const s = window._currentSuggestion || '';
  if (!s) return;
  document.getElementById('new-thought-input').value = s;
  document.getElementById('neg-warn').textContent = '';
  document.getElementById('block-box').style.display = 'none';
  window._prevSuggestions = [];
  window._currentSuggestion = '';
  proceedToResult(s);
}

// ══════════════════════════════════════════
// SHOW RESULT  (위기 → 부정 순서로 차단)
// ══════════════════════════════════════════
async function showResult() {
  const newThought = document.getElementById('new-thought-input').value.trim();
  if (!newThought) { alert('새로운 생각을 먼저 적어주세요 🌱'); return; }

  // ① 위기 키워드 먼저 체크 — AI 문맥 확인
  const hasCrisisInNew = crisisKeywords.some(kw => newThought.includes(kw));
  if (hasCrisisInNew) {
    let isCrisis = true;
    try {
      const cr = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 10,
          messages: [{ role: 'user', content: `다음 문장이 자해·자살·삶을 끝내고 싶은 감정을 직접 표현하고 있나요? "예" 또는 "아니오"만 출력하세요.\n\n문장: "${newThought.replace(/"/g,"'")}"` }]
        })
      });
      const cd = await cr.json();
      isCrisis = cd.content.map(b => b.text || '').join('').trim().includes('예');
    } catch(e) { /* 연결 실패 시 위기로 간주 */ }

    if (isCrisis) {
      // 위로카드 완성 완전 차단 — 위기 안내 표시
      document.getElementById('neg-warn').innerHTML = `
        🚨 위로 카드에는 이런 표현을 담을 수 없어요.<br>
        <span style="font-size:12px;line-height:1.9;display:block;margin-top:5px;">
          지금 많이 힘드신가요? 혼자 버티지 않아도 돼요.<br>
          <strong>자살예방상담전화 1393</strong> / <strong>청소년전화 1388</strong> (24시간 무료)
        </span>`;
      document.getElementById('neg-warn').style.color = '#c0002a';
      document.getElementById('block-box').style.display = 'none';
      return; // 완전 차단
    }
  }

  // ② 일반 부정어 체크 — AI 재확인
  let isNegative = negKeywords.some(k => newThought.includes(k));
  if (isNegative) {
    try {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 10,
          messages: [{ role: 'user', content: `다음 문장이 전체적으로 긍정적인지 부정적인지 판단하세요. "긍정" 또는 "부정" 중 하나만 출력하세요.\n\n문장: "${newThought.replace(/"/g,"'")}"` }]
        })
      });
      const d = await res.json();
      isNegative = d.content.map(b => b.text || '').join('').trim().includes('부정');
    } catch(e) { /* 키워드 판단 유지 */ }
  }

  if (isNegative) {
    document.getElementById('block-box').style.display = 'block';
    document.getElementById('suggest-preview').textContent = '추천 문장 생성 중...';
    document.getElementById('block-box').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    window._prevSuggestions = [];
    window._currentSuggestion = '';
    await aiSuggestPositive(true);
    return;
  }

  proceedToResult(newThought);
}

async function proceedToResult(newThought) {
  const oldThought = document.getElementById('user-input').value.trim();
  document.getElementById('popup-old').textContent = oldThought;
  document.getElementById('popup-new').textContent  = newThought;

  let aiMsg = '오늘 자신의 마음을 들여다보고 생각을 바꾸는 용기를 냈어요. 그게 쉬운 일이 아닌데 정말 잘 했어요 💙';
  if (nlpOn) {
    try {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 200,
          messages: [{
            role: 'user',
            content: `청소년이 부정적 생각을 긍정적으로 바꿨습니다. 아래 상황에 꼭 맞는 따뜻한 마무리 말을 2문장으로만 써주세요. 
일반적인 칭찬 문구("잘 했어요", "용기 있어요") 말고, 이 사람의 구체적 상황을 반영한 개인화된 문장으로 써주세요.
전: "${oldThought.replace(/"/g,"'")}"
후: "${newThought.replace(/"/g,"'")}"`
          }]
        })
      });
      const d = await res.json();
      aiMsg = d.content.map(b => b.text || '').join('').trim() || aiMsg;
    } catch(e) {}
  }
  document.getElementById('popup-ai-msg').textContent = aiMsg;
  document.getElementById('result-popup').classList.add('show');
}

function closeResult() {
  document.getElementById('result-popup').classList.remove('show');
}

